{
  "extends": "./tsconfig.base.json",
  "include": ["src", "virtual.d.ts"],
  "compilerOptions": {
    "module": "ES2022",
    "outDir": "./dist",
    "rootDir": ".",
    // TODO: Due to the shim for Deno imports in `server.ts`, we can't use moduleResolution: 'node16' or the types get very weird.
    "moduleResolution": "Bundler"
  }
}
